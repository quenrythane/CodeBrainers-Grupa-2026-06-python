    {
      "name": "PUT employees",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData;",
              "",
              "pm.test(\"Response body is valid JSON when present\", function () {",
              "    if (pm.response.text()) {",
              "        jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.be.an(\"object\");",
              "    }",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    pm.test(\"Status code is 200\", function () {",
              "        pm.response.to.have.status(200);",
              "    });",
              "",
              "    pm.test(\"Success response has expected employee fields\", function () {",
              "        if (!jsonData) {",
              "            jsonData = pm.response.json();",
              "        }",
              "        pm.expect(jsonData).to.have.property(\"name\");",
              "        pm.expect(jsonData).to.have.property(\"salary\");",
              "        pm.expect(jsonData).to.have.property(\"age\");",
              "        pm.expect(jsonData).to.have.property(\"position\");",
              "        pm.expect(jsonData).to.have.property(\"on_leave\");",
              "    });",
              "",
              "    pm.test(\"Success response echoes updated position\", function () {",
              "        if (!jsonData) {",
              "            jsonData = pm.response.json();",
              "        }",
              "        pm.expect(jsonData.position).to.eql(\"Junior QA\");",
              "    });",
              "",
              "    pm.test(\"Success response includes expected primitive types\", function () {",
              "        if (!jsonData) {",
              "            jsonData = pm.response.json();",
              "        }",
              "        pm.expect(jsonData.name).to.be.a(\"string\");",
              "        pm.expect(jsonData.salary).to.be.a(\"number\");",
              "        pm.expect(jsonData.age).to.be.a(\"number\");",
              "        pm.expect(jsonData.position).to.be.a(\"string\");",
              "        pm.expect(jsonData.on_leave).to.be.a(\"boolean\");",
              "    });",
              "} else if (pm.response.code === 422) {",
              "    pm.test(\"Status code is 422\", function () {",
              "        pm.response.to.have.status(422);",
              "    });",
              "",
              "    pm.test(\"Validation error payload has expected shape\", function () {",
              "        if (!jsonData) {",
              "            jsonData = pm.response.json();",
              "        }",
              "        pm.expect(jsonData).to.have.property(\"detail\");",
              "        pm.expect(jsonData.detail).to.be.an(\"array\").that.is.not.empty;",
              "    });",
              "",
              "    pm.test(\"Validation error includes body.name pattern mismatch\", function () {",
              "        if (!jsonData) {",
              "            jsonData = pm.response.json();",
              "        }",
              "        const matchingDetail = jsonData.detail.find(function (item) {",
              "            return item &&",
              "                item.type === \"string_pattern_mismatch\" &&",
              "                Array.isArray(item.loc) &&",
              "                item.loc.length >= 2 &&",
              "                item.loc[0] === \"body\" &&",
              "                item.loc[1] === \"name\";",
              "        });",
              "",
              "        pm.expect(matchingDetail, \"Expected a detail item for body.name pattern mismatch\").to.exist;",
              "        pm.expect(matchingDetail.msg).to.be.a(\"string\").and.not.empty;",
              "        pm.expect(matchingDetail.input).to.be.a(\"string\");",
              "    });",
              "} else {",
              "    pm.test(\"Response status is one of the handled cases\", function () {",
              "        pm.expect(pm.response.code, \"Expected status 200 or 422\").to.be.oneOf([200, 422]);",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
